{
  "name": "mark",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @mark/api dev",
    "dev:mobile": "pnpm --filter @mark/mobile dev",
    "test": "pnpm --filter @mark/api test",
    "test:watch": "pnpm --filter @mark/api test:watch",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  }
}
